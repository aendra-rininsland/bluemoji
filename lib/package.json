{
  "name": "@aendra/bluemoji",
  "version": "5.0.0",
  "description": "Client library for Bluemoji (moji.blue)",
  "keywords": [
    "atproto"
  ],
  "license": "ISC",
  "author": "Ændra Rininsland",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./facet": {
      "types": "./dist/facet/index.d.ts",
      "import": "./dist/facet.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render.js"
    },
    "./components/webcomponent/picker": "./src/components/webcomponent/picker.ts",
    "./components/webcomponent/webcomponent": "./src/components/webcomponent/webcomponent.ts"
  },
  "scripts": {
    "test": "tsx src/**/*.test.ts",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "codegen": "lex gen-api ./src/client  ../lexicons/app/bsky/*/* ../lexicons/com/atproto/*/* ../lexicons/blue/moji/*/*"
  },
  "dependencies": {
    "@atproto/api": "^0.19.11",
    "@atproto/lexicon": "^0.6.2",
    "@dotlottie/dotlottie-js": "^1.6.3",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@lottiefiles/dotlottie-web": "^0.71.0",
    "lottie-react-native": "^7.3.6",
    "multiformats": "^9.9.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.9.9",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "swc": "^1.0.11",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "react-native": "^0.74.4"
  },
  "engines": {
    "node": ">=24"
  }
}
