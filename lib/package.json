{
  "name": "@aendra/bluemoji",
  "version": "4.0.0",
  "scripts": {
    "test": "tsx src/**/*.test.ts",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "atproto"
  ],
  "author": "Ændra Rininsland",
  "license": "ISC",
  "description": "Client library for Bluemoji (moji.blue)",
  "dependencies": {
    "@atproto/api": "^0.13.3",
    "@atproto/lexicon": "^0.4.0",
    "@dotlottie/dotlottie-js": "^0.8.1",
    "@lottiefiles/dotlottie-react": "^0.8.9",
    "@lottiefiles/dotlottie-web": "^0.30.2",
    "lottie-react-native": "^6.7.2",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.11",
    "swc": "^1.0.11",
    "vite": "^5.4.1"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./render": {
      "require": "./dist/render.cjs",
      "default": "./dist/render.js",
      "types": "./src/render/index.ts"
    },
    "./facet": {
      "require": "./dist/facet.cjs",
      "default": "./dist/facet.js",
      "types": "./src/facet/index.ts"
    },
    "./components/*": "./src/components/*"
  },
  "main": "./dist/facet.cjs",
  "peerDependencies": {
    "react-native": "^0.74.4"
  },
  "files": [
    "dist",
    "src"
  ]
}
