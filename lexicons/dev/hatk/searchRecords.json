{
  "lexicon": 1,
  "id": "dev.hatk.searchRecords",
  "defs": {
    "main": {
      "type": "query",
      "description": "Full-text search across a collection.",
      "parameters": {
        "type": "params",
        "required": ["collection", "q"],
        "properties": {
          "collection": {
            "type": "string"
          },
          "q": {
            "type": "string",
            "description": "Search query"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
          },
          "cursor": {
            "type": "string"
          },
          "fuzzy": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "unknown"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
