{
  "lexicon": 1,
  "id": "dev.hatk.getRecords",
  "defs": {
    "main": {
      "type": "query",
      "description": "List records from a collection with optional filters.",
      "parameters": {
        "type": "params",
        "required": ["collection"],
        "properties": {
          "collection": {
            "type": "string"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
          },
          "cursor": {
            "type": "string"
          },
          "sort": {
            "type": "string"
          },
          "order": {
            "type": "string"
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "unknown"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
